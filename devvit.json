{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "ancientbeast666",
  "permissions": {
    "redis": true,
    "http": {
      "enable": true
    }
  },
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "entry": "splash.html",
        "height": "regular"
      },
      "game": {
        "entry": "game.html",
        "height": "regular"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Play Ancient Beast",
        "description": "Create a new Ancient Beast match post",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/post-create"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install"
  },
  "scripts": {
    "build": "webpack --mode=production --env target=devvit && esbuild src/devvit/server.ts --bundle --platform=node --format=cjs --outfile=dist/server/index.cjs --external:node:* --main-fields=module,main",
    "dev": "webpack --mode=development --watch --env target=devvit & esbuild src/devvit/server.ts --bundle --platform=node --format=cjs --outfile=dist/server/index.cjs --external:node:* --main-fields=module,main --watch"
  },
  "dev": {
    "subreddit": "ancientbeast666_dev"
  }
}