{
	"compilerOptions": {
		"outDir": "./deploy/",
		"sourceMap": true,
		"module": "esnext",
		"lib": ["ESNext", "dom"],
		"target": "es2017",
		"moduleResolution": "node",
		"allowJs": true,
		"noImplicitThis": true,
		"resolveJsonModule": true,
		"allowSyntheticDefaultImports": true,
		"skipLibCheck": true,
		"esModuleInterop": true,
		"noImplicitAny": false,
		"strict": false,
		"types": ["jest", "jquery"]
	},
	"include": ["src", "types", "assets"],
	"exclude": ["node_modules", "src/devvit/game-entry.ts"]
}
